diff --git a/python/sglang/srt/hardware_backend/mlx/kv_cache/attention_wrapper.py b/python/sglang/srt/hardware_backend/mlx/kv_cache/attention_wrapper.py
--- a/python/sglang/srt/hardware_backend/mlx/kv_cache/attention_wrapper.py
+++ b/python/sglang/srt/hardware_backend/mlx/kv_cache/attention_wrapper.py
@@ -183,9 +183,17 @@ class MLXAttentionWrapper(nn.Module):
         all_v = []

         for i in range(B):
-            layer_caches[i].write_token(keys[i : i + 1], values[i : i + 1])
-
-            k_all, v_all = layer_caches[i].get_kv()
+            # Use update_and_fetch (canonical mlx_lm cache API) instead of
+            # write_token + get_kv. update_and_fetch exists on every cache
+            # type — including RotatingKVCache (sliding-window, used by
+            # Gemma 4's sliding-attention layers), which lacks the
+            # write_token / get_kv pair. Crash detected 2026-05-18 on
+            # gemma4 MoE: AttributeError on RotatingKVCache.write_token at
+            # this line. Behavior unchanged for ContiguousKVCache.
+            k_all, v_all = layer_caches[i].update_and_fetch(
+                keys[i : i + 1], values[i : i + 1]
+            )

             pad = pad_sizes[i]

diff --git a/python/sglang/srt/hardware_backend/mlx/model_runner.py b/python/sglang/srt/hardware_backend/mlx/model_runner.py
--- a/python/sglang/srt/hardware_backend/mlx/model_runner.py
+++ b/python/sglang/srt/hardware_backend/mlx/model_runner.py
@@ -1167,6 +1167,32 @@ class MlxModelRunner:
             )

+        # Non-hybrid batched path: assumes all layers share the same KV
+        # cache shape. Breaks for Gemma 4-style heterogeneous attention
+        # (mix of ContiguousKVCache + RotatingKVCache) — sliding layers'
+        # update_and_fetch returns at most max_size tokens while full
+        # layers return offset tokens, so per-request K/V have different
+        # seq_lens across layers and mx.concatenate ValueErrors at the
+        # batch step. Detect and fall back to serial-per-request decode.
+        # Discovered 2026-05-19 on gemma4 MoE.
+        from mlx_lm.models.cache import RotatingKVCache
+        if any(isinstance(c, RotatingKVCache) for c in caches[0]):
+            per_req_logits = []
+            for i, rid in enumerate(req_ids):
+                last_token = self._req_token_ids[rid][-1]
+                input_ids = mx.array([[last_token]], dtype=mx.int32)
+                out = self.model(input_ids, cache=caches[i])
+                per_req_logits.append(self._extract_logits(out)[:, -1, :])
+            stacked = mx.concatenate(per_req_logits, axis=0)
+            lazy_tokens = mx.argmax(stacked, axis=-1)
+            return MlxPendingDecode(
+                lazy_tokens=lazy_tokens,
+                req_ids=list(req_ids),
+                caches=caches,
+            )
+
         seq_lens = [caches[i][0].offset for i in range(batch_size)]
         layer_caches = [
             [caches[i][layer_idx] for i in range(batch_size)]
