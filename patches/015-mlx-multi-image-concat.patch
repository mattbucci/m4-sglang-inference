+                                        np_arrs = [
+                                            v.numpy() if hasattr(v, "numpy")
+                                            else (_np.asarray(v) if not isinstance(v, (list, tuple))
+                                                  else _np.asarray(v))
+                                            for v in vs
+                                        ]
+                                        mm_kwargs[k] = _mx.array(
