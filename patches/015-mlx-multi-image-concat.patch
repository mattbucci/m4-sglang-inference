+                    pixel_values = None
+                    mm_kwargs: dict = {}
+                    mm = getattr(req, "multimodal_inputs", None)
+                    if mm and getattr(mm, "mm_items", None):
+                        try:
+                            import mlx.core as _mx
+                            import numpy as _np
+
+                            features: list = []
+                            msd_acc: dict[str, list] = {}
+                            for item in mm.mm_items:
+                                feat = getattr(item, "feature", None)
+                                if feat is None:
+                                    continue
+                                features.append(
+                                    feat.numpy() if hasattr(feat, "numpy") else feat
+                                )
+                                msd = getattr(item, "model_specific_data", None) or {}
+                                for k, v in msd.items():
+                                    msd_acc.setdefault(k, []).append(v)
+
+                            if features:
