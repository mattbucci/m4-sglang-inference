+                                        if pv_np.ndim == 2:
+                                            pv_np = pv_np[None, ...]
+                                            ip_np = ip_np[None, ...]
+                                        patch_pixels = pv_np.shape[-1]
+                                        patch_size = 16
+                                        C = patch_pixels // (patch_size * patch_size)
+                                        raw_images = []
