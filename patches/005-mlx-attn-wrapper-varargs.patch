From 86d9823e48ebb857cfc5dcf0c0f0cf311e0dfcd9 Mon Sep 17 00:00:00 2001
From: M4 Patch Rebase <claude-rebase@m4.local>
Date: Wed, 20 May 2026 22:37:50 -0700
Subject: [PATCH] Patch 005: mlx-attn-wrapper-varargs

---
 .../mlx/kv_cache/attention_wrapper.py         | 24 +++++++++++++++----
 1 file changed, 19 insertions(+), 5 deletions(-)

diff --git a/python/sglang/srt/hardware_backend/mlx/kv_cache/attention_wrapper.py b/python/sglang/srt/hardware_backend/mlx/kv_cache/attention_wrapper.py
index d9524ab11..61e99b46a 100644
--- a/python/sglang/srt/hardware_backend/mlx/kv_cache/attention_wrapper.py
+++ b/python/sglang/srt/hardware_backend/mlx/kv_cache/attention_wrapper.py
@@ -67,13 +67,21 @@ class MLXAttentionWrapper(nn.Module):
         object.__setattr__(self, "_inner", inner)
         object.__setattr__(self, "_layer_idx", layer_idx)
 
-    def __call__(self, x: mx.array, mask: Any = None, cache: Any = None) -> mx.array:
+    def __call__(self, x: mx.array, *args, **kwargs) -> mx.array:
         ctx = get_context()
         if ctx is None:
-            return self._inner(x, mask=mask, cache=cache)
-        return self._batched_decode(x, ctx)
-
-    def _batched_decode(self, x: mx.array, ctx: BatchedDecodeContext) -> mx.array:
+            return self._inner(x, *args, **kwargs)
+        # Some models (ministral3 / Devstral) pass attn_scale as the first
+        # extra positional arg: attn(x, attn_scale, mask, cache).
+        attn_scale = args[0] if args else None
+        return self._batched_decode(x, ctx, attn_scale=attn_scale)
+
+    def _batched_decode(
+        self,
+        x: mx.array,
+        ctx: BatchedDecodeContext,
+        attn_scale: Any = None,
+    ) -> mx.array:
         inner = self._inner
         layer_idx = self._layer_idx
         B = ctx.batch_size
@@ -101,6 +109,12 @@ class MLXAttentionWrapper(nn.Module):
         queries = inner.rope(queries, offset=offsets)
         keys = inner.rope(keys, offset=offsets)
 
+        # Apply explicit attn_scale if model passes it (ministral3/Devstral
+        # call attn(x, attn_scale, mask, cache); without this, the scale is
+        # silently dropped and outputs are off by a constant factor).
+        if attn_scale is not None:
+            queries = queries * attn_scale
+
         layer_caches = ctx.layer_caches[layer_idx]
         max_len = ctx.max_len
         pad_sizes = ctx.pad_sizes
