@@ -13,9 +13,18 @@ if TYPE_CHECKING:
 class OffsetCache:
     """Data-free shim satisfying mlx-lm's cache protocol.
 
-    Provides ``make_mask`` and ``state`` without storing actual K/V.
+    Provides ``make_mask``, ``state``, ``__getitem__``, ``__setitem__``,
+    ``lengths``, and ``advance`` without storing actual K/V. The subscript
+    + lengths + advance stubs are required by hybrid models like
+    Qwen3.5 / Coder-Next whose ``linear_attn`` layers probe these
+    attributes. Without them, batched decode on those models crashes with
+    ``TypeError: 'OffsetCache' object is not subscriptable``.
     """
 
+    # DeltaNet linear_attn probes `cache.lengths is not None` to decide
+    # whether to advance the conv_state pointer. None = cold path.
+    lengths = None
+
     def __init__(self, offset: int = 0):
         self.offset = offset
 
@@ -23,6 +32,23 @@ class OffsetCache:
     def state(self):
         return ()  # Empty — safe for mx.eval unpacking
 
+    def __getitem__(self, key):
+        # Return None — signals "no cached state" to hybrid layers; they
+        # fall back to a zero-initialized state.
+        return None
+
+    def __setitem__(self, key, value):
+        # Accept and discard — DeltaNet writes state back here, but
+        # OffsetCache by design doesn't persist data.
+        pass
+
+    def __len__(self):
+        return 0
+
+    def advance(self, S):
+        """No-op stub — DeltaNet calls this after writing state."""
+        pass
+
     def make_mask(self, N, **kwargs):
         return None if N == 1 else "causal"
 
@@ -76,7 +102,27 @@ class ContiguousKVCache:
         return (self.keys, self.values)
 
     def make_mask(self, N, **kwargs):
-        return None if N == 1 else "causal"
+        """Return a mask for ``N`` new query tokens against cached keys.
+
+        For chunked-prefill with ``offset > 0`` (second+ chunk), mlx-lm's
+        default ``"causal"`` shorthand produces a square ``(N, N)`` mask
+        that doesn't broadcast against scores of shape
+        ``(1, n_heads, N, offset+N)`` — explicit causal mask required.
+        Sliding-window models pass ``window_size``; we honour it by
+        bit-anding the within-window check into the causal mask.
+        """
+        if N == 1:
+            return None
+        if self.offset > 0:
+            S = self.offset + N
+            window = kwargs.get("window_size")
+            q_idx = self.offset + mx.arange(N)
+            k_idx = mx.arange(S)
+            mask = q_idx[:, None] >= k_idx[None, :]
+            if window is not None:
+                mask = mask & (q_idx[:, None] - k_idx[None, :] < window)
+            return mask
+        return "causal"
 
     def _grow(self, required: int) -> None:
         """Double the buffer until it can hold *required* tokens."""
