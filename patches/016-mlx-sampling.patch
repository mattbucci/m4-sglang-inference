+    def register_sampling(self, req_id: str, sampling_params: Any) -> None:
+        """Record a request's sampling spec; absent/top_k==1 stays greedy.
+
+        A genuine top_k=1 request with temperature>0 is indistinguishable
+        from SGLang's greedy encoding and is served greedy (documented
+        aliasing, patches/README.md).
+        """
+        if sampling_params is None:
+            return
+        spec = (
+            float(sampling_params.temperature),
+            float(sampling_params.top_p),
+            int(sampling_params.top_k),
+            float(sampling_params.min_p),
+        )
+        if spec[2] == 1:
+            return
+        if _mlx_make_sampler is None:
+            logger.warning(
+                "mlx_lm.sample_utils.make_sampler unavailable — request %s "
+                "with sampling params served greedy",
+                req_id,
+            )
+            return
+        self._req_sampling[req_id] = spec
+
+    def _sampler_for(self, spec: tuple[float, float, int, float]):
+        sampler = self._sampler_cache.get(spec)
+        if sampler is None:
+            temperature, top_p, top_k, min_p = spec
+            sampler = _mlx_make_sampler(
+                temp=temperature,
+                top_p=top_p,
+                min_p=min_p,
+                # SGLang encodes "no top-k" as TOP_K_ALL (1<<30); make_sampler
+                # disables top-k at 0.
+                top_k=0 if top_k >= (1 << 30) else top_k,
+            )
+            self._sampler_cache[spec] = sampler
+        return sampler
+
+    def _select_tokens(self, last_logits: mx.array, req_ids: list[str]) -> mx.array:
+        """Per-request token selection over (B, vocab) last-position logits.
+
+        The sampler consumes LOG-PROBABILITIES — ``apply_top_p``
+        exponentiates and cumsums, so raw logits would give wrong nuclei —
+        hence the logsumexp normalization on the sampled path. The all-greedy
+        path is today's exact ``mx.argmax`` graph, untouched.
+        """
+        specs = [self._req_sampling.get(rid) for rid in req_ids]
+        if all(s is None for s in specs):
+            return mx.argmax(last_logits, axis=-1)
+        logprobs = last_logits - mx.logsumexp(last_logits, axis=-1, keepdims=True)
+        if len(set(specs)) == 1:
+            return self._sampler_for(specs[0])(logprobs)
+        rows = []
+        for i, s in enumerate(specs):
+            if s is None:
+                rows.append(mx.argmax(last_logits[i : i + 1], axis=-1))
+            else:
+                rows.append(self._sampler_for(s)(logprobs[i : i + 1]))
+        return mx.concatenate(rows, axis=0)
+
