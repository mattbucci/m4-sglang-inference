Subject: [PATCH] Patch 009: mlx-nemotron-h-support

---
 .../mlx/kv_cache/attention_wrapper.py         | 24 ++++---
 .../mlx/kv_cache/model_patching.py            | 71 ++++++++++++++++---
 .../srt/hardware_backend/mlx/model_runner.py  | 24 +++++--
 3 files changed, 97 insertions(+), 22 deletions(-)

diff --git a/python/sglang/srt/hardware_backend/mlx/kv_cache/attention_wrapper.py b/python/sglang/srt/hardware_backend/mlx/kv_cache/attention_wrapper.py
index 61e99b46a..4c70b5bd5 100644
--- a/python/sglang/srt/hardware_backend/mlx/kv_cache/attention_wrapper.py
+++ b/python/sglang/srt/hardware_backend/mlx/kv_cache/attention_wrapper.py
@@ -90,10 +90,15 @@ class MLXAttentionWrapper(nn.Module):
         keys = inner.k_proj(x)
         values = inner.v_proj(x)
 
-        head_dim = queries.shape[-1] // inner.n_heads
-        queries = queries.reshape(B, 1, inner.n_heads, head_dim)
-        keys = keys.reshape(B, 1, inner.n_kv_heads, head_dim)
-        values = values.reshape(B, 1, inner.n_kv_heads, head_dim)
+        # mlx_lm uses n_heads/n_kv_heads; mlx_vlm and NemotronH use
+        # num_attention_heads/num_key_value_heads. Accept either.
+        n_heads = getattr(inner, "n_heads", None) or inner.num_attention_heads
+        n_kv_heads = getattr(inner, "n_kv_heads", None) or inner.num_key_value_heads
+
+        head_dim = queries.shape[-1] // n_heads
+        queries = queries.reshape(B, 1, n_heads, head_dim)
+        keys = keys.reshape(B, 1, n_kv_heads, head_dim)
+        values = values.reshape(B, 1, n_kv_heads, head_dim)
 
         if hasattr(inner, "q_norm"):
             queries = inner.q_norm(queries)
@@ -104,10 +109,13 @@ class MLXAttentionWrapper(nn.Module):
         keys = keys.transpose(0, 2, 1, 3)
         values = values.transpose(0, 2, 1, 3)
 
-        # Vectorized RoPE with per-batch offsets
-        offsets = ctx.offsets
-        queries = inner.rope(queries, offset=offsets)
-        keys = inner.rope(keys, offset=offsets)
+        # Vectorized RoPE with per-batch offsets. NemotronHAttention has
+        # no RoPE — position encoding is handled by interleaved Mamba
+        # layers — so we skip the rope call when inner.rope is absent.
+        if hasattr(inner, "rope"):
+            offsets = ctx.offsets
+            queries = inner.rope(queries, offset=offsets)
+            keys = inner.rope(keys, offset=offsets)
 
         # Apply explicit attn_scale if model passes it (ministral3/Devstral
         # call attn(x, attn_scale, mask, cache); without this, the scale is
diff --git a/python/sglang/srt/hardware_backend/mlx/kv_cache/model_patching.py b/python/sglang/srt/hardware_backend/mlx/kv_cache/model_patching.py
index b89bb6e76..37540ee48 100644
--- a/python/sglang/srt/hardware_backend/mlx/kv_cache/model_patching.py
+++ b/python/sglang/srt/hardware_backend/mlx/kv_cache/model_patching.py
@@ -7,20 +7,56 @@ from sglang.srt.hardware_backend.mlx.kv_cache.attention_wrapper import (
 )
 
 
+def _is_attention_module(m: Any) -> bool:
+    """True iff *m* looks like a standard self-attention module.
+
+    Standard attention has q_proj/k_proj/v_proj/o_proj projections.
+    NemotronHAttention, Qwen3NextAttention, Llama-family Attention,
+    and Mistral Attention all match. Mamba mixers (Mamba2/DeltaNet
+    linear-attn) have in_proj/out_proj patterns; MoE mixers have
+    gate + experts. Either of those fails the q_proj test.
+
+    Also accepts an already-installed ``MLXAttentionWrapper`` (probes
+    its ``_inner``) — ``find_attention_layers`` is re-run after
+    ``patch_model_attention``, so this keeps the discovery idempotent.
+    """
+    if isinstance(m, MLXAttentionWrapper):
+        m = m._inner
+    return all(hasattr(m, n) for n in ("q_proj", "k_proj", "v_proj", "o_proj"))
+
+
 def find_attention_layers(model: Any) -> tuple[list[Any], str]:
     """Find transformer layers and the canonical attention attribute name.
 
-    Hybrid models (Qwen3.5 DeltaNet, Qwen3.6 GDN, Coder-Next mamba)
-    alternate ``linear_attn`` / DeltaNet layers with standard ``self_attn``
-    layers. Layer 0 may be the DeltaNet flavor and have no ``self_attn``
-    at all, which used to raise ``ValueError: No attention attribute in
-    layer type Qwen3_5DecoderLayer``. Scan the full list and return the
-    attribute name used by the first standard-attention layer; the
-    patcher then skips layers that don't have it.
+    Hybrid models alternate "attention" and "non-attention" mixers.
+    Examples:
+      - Qwen3.5 / Qwen3.6: ``self_attn`` (standard) vs ``linear_attn``
+        (DeltaNet); layer 0 may be DeltaNet-only.
+      - NemotronH (Nemotron-3-Nano-30B-A3B): all layers expose ``mixer``;
+        block_type "*" → NemotronHAttention, "M" → NemotronHMamba2Mixer,
+        "E" → NemotronHMoE, "-" → NemotronHMLP.
+      - Coder-Next-80B mamba: similar pattern.
+
+    Probe order:
+      1. ``self_attn`` (Qwen/Llama/Mistral)
+      2. ``attention`` (some Qwen variants)
+      3. ``mixer`` *if* at least one layer's mixer is a standard
+         attention module (q_proj/k_proj/v_proj/o_proj all present).
+
+    Raises ValueError only when none of these match — that means the
+    architecture is genuinely new and needs another probe added here.
     """
     root = getattr(model, "language_model", model)
     container = getattr(root, "model", root)
-    layer_list = getattr(container, "layers", None) or getattr(root, "layers", [])
+    layer_list = (
+        getattr(container, "layers", None)
+        or getattr(root, "layers", [])
+    )
+    if not layer_list:
+        # Some models route the layer list through a `backbone` (NemotronH).
+        backbone = getattr(container, "backbone", None) or getattr(root, "backbone", None)
+        if backbone is not None:
+            layer_list = getattr(backbone, "layers", [])
 
     if not layer_list:
         return layer_list, "self_attn"
@@ -30,9 +66,16 @@ def find_attention_layers(model: Any) -> tuple[list[Any], str]:
             if hasattr(layer, attr_name):
                 return layer_list, attr_name
 
+    # NemotronH-style: layers expose `.mixer` and we need to confirm at
+    # least one is real attention (not Mamba/MoE).
+    for layer in layer_list:
+        m = getattr(layer, "mixer", None)
+        if m is not None and _is_attention_module(m):
+            return layer_list, "mixer"
+
     raise ValueError(
-        f"No attention attribute (self_attn / attention) on any layer "
-        f"in {type(layer_list[0])}"
+        f"No attention attribute (self_attn / attention / mixer) found "
+        f"on any layer in {type(layer_list[0])}"
     )
 
 
@@ -45,6 +88,10 @@ def patch_model_attention(model: Any) -> int:
     Layers that don't have the resolved attribute (DeltaNet ``linear_attn``
     layers in a hybrid model, say) are skipped — their cache type lives
     elsewhere and is handled by the model's own ``make_cache``.
+
+    For ``attn_attr == "mixer"`` (NemotronH-style), each layer's mixer is
+    additionally type-checked: only real attention mixers (q/k/v/o_proj
+    all present) get the wrapper; Mamba/MoE/MLP mixers are left alone.
     """
     layer_list, attn_attr = find_attention_layers(model)
     patched = 0
@@ -52,6 +99,10 @@ def patch_model_attention(model: Any) -> int:
         attn = getattr(layer, attn_attr, None)
         if attn is None or isinstance(attn, MLXAttentionWrapper):
             continue
+        # When iterating `mixer`, the same attribute is shared by Mamba/MoE
+        # layers — skip those so we don't wrap non-attention mixers.
+        if attn_attr == "mixer" and not _is_attention_module(attn):
+            continue
         setattr(layer, attn_attr, MLXAttentionWrapper(attn, idx))
         patched += 1
     return patched
diff --git a/python/sglang/srt/hardware_backend/mlx/model_runner.py b/python/sglang/srt/hardware_backend/mlx/model_runner.py
index 9d1a0fa16..0095bc6d6 100644
--- a/python/sglang/srt/hardware_backend/mlx/model_runner.py
+++ b/python/sglang/srt/hardware_backend/mlx/model_runner.py
@@ -638,18 +638,34 @@ class MlxModelRunner:
         layer 0 may be a DeltaNet layer with only ``linear_attn`` (no
         ``self_attn``). Sample the first layer that actually has
         ``attn_attr`` instead of blindly taking ``layer_list[0]``.
+
+        For NemotronH-style hybrids, every layer shares the ``mixer``
+        attribute but the type alternates (Mamba2 / MoE / MLP / Attention).
+        We must check that the mixer is actually an attention module —
+        unwrap any ``MLXAttentionWrapper`` and verify q/k/v/o_proj are
+        present before sampling.
         """
         layer_list, attn_attr = find_attention_layers(self.model)
         if not layer_list:
             raise RuntimeError("Cannot determine attention config: no layers found")
         sample_attn = None
         for layer in layer_list:
-            sample_attn = getattr(layer, attn_attr, None)
-            if sample_attn is not None:
-                break
+            candidate = getattr(layer, attn_attr, None)
+            if candidate is None:
+                continue
+            # Peek through the patcher wrapper.
+            inner = candidate._inner if isinstance(candidate, MLXAttentionWrapper) else candidate
+            # For mixer-style hybrids, layer 0 may be a Mamba/MoE mixer; skip.
+            if attn_attr == "mixer" and not all(
+                hasattr(inner, n) for n in ("q_proj", "k_proj", "v_proj", "o_proj")
+            ):
+                continue
+            sample_attn = candidate
+            break
         if sample_attn is None:
             raise RuntimeError(
-                f"No layer has attribute {attn_attr!r}; cannot derive attn config"
+                f"No layer has a real attention module under {attn_attr!r}; "
+                f"cannot derive attn config"
             )
         if isinstance(sample_attn, MLXAttentionWrapper):
             sample_attn = sample_attn._inner
