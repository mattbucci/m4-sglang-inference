+def _build_gemma4_image_only_processor(
+    model_path, trust_remote_code, revision, **kwargs
+):
+    """Build a Gemma4Processor variant that allows feature_extractor=None +
+    video_processor=None for image+text-only serving.
+
+    Upstream `google/gemma-4-26b-a4b-it` and the mlx-community quantizations ship
+    only `processor_config.json` (image processor + token-id metadata). Neither
+    `preprocessor_config.json` (the audio feature_extractor) nor
+    `video_preprocessor_config.json` is present. transformers 5.5.3's
+    `AutoProcessor.from_pretrained` calls `AutoFeatureExtractor.from_pretrained`
+    and `AutoVideoProcessor.from_pretrained` because `Gemma4Processor.__init__`
+    requires all four sub-components — both raise `OSError` and the construction
+    fails before any image processing path can run.
+
+    SGLang's downstream `Gemma4SGLangProcessor` already accesses
+    `feature_extractor` and `video_processor` via `getattr(..., None)` with safe
+    defaults, so image+text serving doesn't depend on those sub-components — only
+    the constructor does. This helper replays Gemma4Processor.__init__'s body
+    plus ProcessorMixin.__init__'s token-id-list setup, skipping the strict type
+    check on the missing sub-components.
+    """
+    from transformers import AutoImageProcessor, AutoTokenizer, Gemma4Processor
+
+    tokenizer_kwargs = {k: v for k, v in kwargs.items() if k != "size"}
+    tokenizer = AutoTokenizer.from_pretrained(
+        model_path,
+        trust_remote_code=trust_remote_code,
+        revision=revision,
+        **tokenizer_kwargs,
+    )
+    image_processor = AutoImageProcessor.from_pretrained(
+        model_path,
+        trust_remote_code=trust_remote_code,
+        revision=revision,
+        **tokenizer_kwargs,
+    )
+
+    class Gemma4ImageOnlyProcessor(Gemma4Processor):
+        def __init__(self, image_processor, tokenizer, chat_template=None,
+                     image_seq_length=280, audio_seq_length=750, audio_ms_per_token=40):
+            # Body of Gemma4Processor.__init__ up to (but not including) super().__init__()
+            self.image_seq_length = image_seq_length
+            self.image_token_id = tokenizer.image_token_id
+            self.boi_token = tokenizer.boi_token
+            self.eoi_token = tokenizer.eoi_token
+            self.image_token = tokenizer.image_token
+            tokenizer.add_special_tokens({"additional_special_tokens": ["<|video|>"]})
+            self.video_token = "<|video|>"
+            self.video_token_id = tokenizer.convert_tokens_to_ids(self.video_token)
+            self.audio_seq_length = audio_seq_length
+            self.audio_ms_per_token = audio_ms_per_token
+            self.audio_token_id = getattr(tokenizer, "audio_token_id", None)
+            self.audio_token = getattr(tokenizer, "audio_token", None)
+            self.boa_token = getattr(tokenizer, "boa_token", None)
+            self.eoa_token = getattr(tokenizer, "eoa_token", None)
+            # Sub-component attrs without ProcessorMixin's strict type check
+            self.feature_extractor = None
+            self.image_processor = image_processor
+            self.tokenizer = tokenizer
+            self.video_processor = None
+            self.chat_template = chat_template
+            # ProcessorMixin attrs used by create_mm_token_type_ids
+            self.image_ids = [self.image_token_id]
+            self.video_ids = [self.video_token_id]
+            self.audio_ids = [self.audio_token_id]
+
+    return Gemma4ImageOnlyProcessor(
+        image_processor=image_processor,
+        tokenizer=tokenizer,
+        chat_template=getattr(tokenizer, "chat_template", None),
+    )
+
