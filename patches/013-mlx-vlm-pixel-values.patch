                     full_token_ids = list(req.fill_ids)
+                    # Patch 013: extract pixel_values from multimodal_inputs
+                    # (set by SGLang's processor when an image is in the
+                    # request). MlxModelRunner.prefill threads it to
+                    # TextOnlyVLMShim which routes to the full vlm.__call__
+                    # when present. The original plumbing landed Apr-18 as
+                    # commit f20ee6e and was lost in the v0.5.11 rebase —
+                    # this patch is the restoration receipt.
+                    pixel_values = None
+                    mm_kwargs: dict = {}
+                    mm = getattr(req, "multimodal_inputs", None)
+                    if mm and getattr(mm, "mm_items", None):
+                        item = mm.mm_items[0]
+                        feature = getattr(item, "feature", None)
+                        if feature is not None:
+                            try:
+                                import mlx.core as _mx
+
+                                # mlx_vlm wants an MLX array. SGLang's
+                                # multimodal processor returns a torch
+                                # tensor; convert via numpy bridge.
+                                pixel_values = _mx.array(
+                                    feature.numpy()
+                                    if hasattr(feature, "numpy")
+                                    else feature
+                                )
+                                # Forward model-specific kwargs that
+                                # individual VLMs need alongside
+                                # pixel_values. Pixtral / Mistral3
+                                # require image_sizes for the patch
+                                # merger; Qwen2-VL uses image_grid_thw;
+                                # Qwen3.5/3.6 use video_grid_thw +
+                                # second_per_grid_ts. Anything in
+                                # model_specific_data gets passed
+                                # through — the model decides what to
+                                # consume via **kwargs.
+                                msd = getattr(item, "model_specific_data", None) or {}
+                                for k, v in msd.items():
+                                    try:
+                                        if hasattr(v, "numpy"):
+                                            mm_kwargs[k] = _mx.array(v.numpy())
+                                        elif isinstance(v, (list, tuple)):
+                                            mm_kwargs[k] = v
+                                        else:
+                                            mm_kwargs[k] = _mx.array(v)
+                                    except Exception:
+                                        mm_kwargs[k] = v
+                            except Exception:
+                                pixel_values = None
