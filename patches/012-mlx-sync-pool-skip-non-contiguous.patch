From 68df7c31588263d8349bc6f37dc5f727ffb2e44e Mon Sep 17 00:00:00 2001
From: M4 Patch Rebase <claude-rebase@m4.local>
Date: Wed, 20 May 2026 22:37:51 -0700
Subject: [PATCH] Patch 012: mlx-sync-pool-skip-non-contiguous

---
 .../srt/hardware_backend/mlx/model_runner.py  | 43 +++++++++++--------
 1 file changed, 25 insertions(+), 18 deletions(-)

diff --git a/python/sglang/srt/hardware_backend/mlx/model_runner.py b/python/sglang/srt/hardware_backend/mlx/model_runner.py
index 993d3b4b4..ca53b2762 100644
--- a/python/sglang/srt/hardware_backend/mlx/model_runner.py
+++ b/python/sglang/srt/hardware_backend/mlx/model_runner.py
@@ -803,31 +803,38 @@ class MlxModelRunner:
 
     def _sync_new_kv_to_pool(
         self,
-        cache: list[ContiguousKVCache],
+        cache: list,
         cache_start: int,
         slot_ids: list[int],
     ) -> None:
-        """Sync KV from contiguous cache to pool at the given slot IDs."""
+        """Sync KV from contiguous cache to pool at the given slot IDs.
+
+        For hybrid models, the per-layer cache list is heterogeneous —
+        ContiguousKVCache for full-attention layers, ArraysCache for
+        DeltaNet/Mamba2 recurrent state, RotatingKVCache for sliding
+        attention. Only ContiguousKVCache layers have the
+        ``(1, n_kv_heads, S, head_dim)`` shape the pool expects; the
+        others either don't carry per-token KV at all (linear/SSM) or
+        carry it in a wrap-around buffer with different shape. Filter
+        to ContiguousKVCache layers only and write each per-layer via
+        ``set_kv``. Non-attention pool buffers stay zero-initialised —
+        radix prefix reuse for hybrid models would still produce wrong
+        outputs on those layers (the linear state can't be cached
+        per-token), so the user must keep ``--disable-radix-cache`` on
+        for correctness. This change is just defence in depth so the
+        write side doesn't crash when radix happens to be enabled.
+        """
         if not slot_ids or self._kv_pool is None:
             return
-        num_layers = len(cache)
         end = cache_start + len(slot_ids)
         slot_ids_mx = mx.array(slot_ids, dtype=mx.int32)
-        # TODO: Standardize ContiguousKVCache size to avoid transpose
-        # Transpose cache (1, n_kv_heads, S, head_dim) → pool (S, n_kv_heads, head_dim)
-        k_all = mx.stack(
-            [
-                cache[i].keys[0, :, cache_start:end, :].transpose(1, 0, 2)
-                for i in range(num_layers)
-            ]
-        )
-        v_all = mx.stack(
-            [
-                cache[i].values[0, :, cache_start:end, :].transpose(1, 0, 2)
-                for i in range(num_layers)
-            ]
-        )
-        self._kv_pool.set_kv_all_layers(slot_ids_mx, k_all, v_all)
+        # Transpose cache (1, n_kv_heads, S, head_dim) → pool (S, n_kv_heads, head_dim).
+        for layer_idx, layer_cache in enumerate(cache):
+            if not isinstance(layer_cache, ContiguousKVCache):
+                continue
+            k = layer_cache.keys[0, :, cache_start:end, :].transpose(1, 0, 2)
+            v = layer_cache.values[0, :, cache_start:end, :].transpose(1, 0, 2)
+            self._kv_pool.set_kv(layer_idx, slot_ids_mx, k, v)
 
     def _sync_decode_kv_to_pool(self, req_id: str) -> None:
         """Sync un-flushed decode KV for *req_id* to the shared pool."""
