+    def _reset_mlx_vlm_position_cache(self) -> None:
+        """Clear mlx_vlm-specific position-id caches on the language model.
+
+        ``mlx_vlm/models/qwen3_5/LanguageModel`` caches ``_position_ids``
+        and ``_rope_deltas`` between forward calls and only invalidates them
+        when a new ``pixel_values`` arrives. For multi-request serving this
+        leaks request A's position tensor into request B's prefill — the
+        ``apply_multimodal_rotary_pos_emb`` call then broadcasts a length-A
+        cos/sin against length-B queries and crashes. Reset at every new
+        prefill (extend_start within the same request keeps the cache live,
+        which is correct for chunked prefill).
+        """
+        targets = [self.model]
+        lm = getattr(self.model, "language_model", None)
+        if lm is not None:
+            targets.append(lm)
+        for t in targets:
+            for attr in ("_position_ids", "_rope_deltas"):
+                if hasattr(t, attr) and getattr(t, attr) is not None:
+                    setattr(t, attr, None)
+
     def _release_cache(self, cache: list[ContiguousKVCache]) -> None:
         """Return a cache list to the pool for reuse.

