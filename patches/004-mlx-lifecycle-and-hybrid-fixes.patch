+    def _apply_rope_scaling(self):
+        """Apply linear RoPE scaling if context_length exceeds the model's native max.
+
+        Lets models trained at e.g. 40K serve 256K via linear interpolation.
+        Cheaper than re-training; quality drops at the very long end but
+        the radix-cache + long-context regime is bandwidth-bound either way.
+        """
+        if self._context_length is None:
+            return
+
+        root = getattr(self.model, "language_model", self.model)
+        model_obj = getattr(root, "model", root)
+        config = getattr(model_obj, "args", None) or getattr(root, "args", None)
+        if config is None:
+            return
+
+        native_max = getattr(config, "max_position_embeddings", None)
+        if native_max is None or self._context_length <= native_max:
+            return
+
+        factor = self._context_length / native_max
+        scale = 1.0 / factor
+        logger.info(
+            f"RoPE scaling: context_length={self._context_length} > "
+            f"max_position_embeddings={native_max}, applying linear "
+            f"scale={scale:.4f} (factor={factor:.2f})"
+        )
+
+        import mlx.nn as nn
+
+        layer_list = getattr(model_obj, "layers", [])
+        patched = 0
+        for layer in layer_list:
+            for attr_name in ("self_attn", "attention"):
+                attn = getattr(layer, attr_name, None)
+                if attn is None:
+                    continue
+                inner = attn._inner if isinstance(attn, MLXAttentionWrapper) else attn
+                rope = getattr(inner, "rope", None)
+                if rope is not None and isinstance(rope, nn.RoPE):
+                    inner.rope = nn.RoPE(
+                        dims=rope.dims,
+                        traditional=rope.traditional,
+                        base=rope.base,
+                        scale=scale,
+                    )
+                    patched += 1
+        if patched > 0:
+            logger.info(f"Patched {patched} RoPE modules with scale={scale:.4f}")
+        else:
+            logger.warning("No RoPE modules found to patch")
 
