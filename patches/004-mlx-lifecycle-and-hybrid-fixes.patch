+    def _acquire_cache(self) -> list:
+        """Get a reusable cache list from the pool, or create a new one.
+
+        Hybrid models (Qwen3.5 DeltaNet, Qwen3.6 GDN, Coder-Next mamba)
+        provide ``make_cache()`` which returns a heterogeneous cache list
+        per layer — ``ArraysCache`` for DeltaNet recurrent state,
+        ``RotatingKVCache`` for sliding attention, ``KVCache`` for full
+        attention. For VLM-wrapped hybrids loaded via ``mlx_vlm.load``,
+        ``make_cache`` lives on ``self.model.language_model`` rather than
+        the outer wrapper.
+
+        Hybrid models also bypass the pool: ``ArraysCache`` carries enough
+        internal state (``cache`` list, ``lengths``, possible internal
+        positional buffers we don't introspect) that pool-reuse repeatedly
+        crashes with broadcast-shape errors of the form
+        ``(B, heads, S_stale, D) vs (B, 1, S_new, D)``. Always-fresh
+        ``make_cache()`` per request is a small per-prefill allocation cost
+        and avoids the class of bug entirely. The fp16/turboquant
+        non-hybrid pool reuse path is unaffected.
+        """
+        if self._is_hybrid_model:
+            return self._build_fresh_cache()
+
         if self._cache_pool:
             cache = self._cache_pool.pop()
+            # Reset any state the cache type allows so a returned cache
+            # from a previous request doesn't leak state into a new one.
             for c in cache:
-                c.offset = 0
+                if hasattr(c, "offset"):
+                    c.offset = 0  # ContiguousKVCache / KVCache / RotatingKVCache
+                    # RotatingKVCache has a ring-buffer write index (_idx)
+                    # that also needs reset; otherwise the next request
+                    # writes at the prior request's wrap-around position.
+                    if hasattr(c, "_idx"):
+                        c._idx = 0
+                    # RotatingKVCache also keeps the prior keys/values
+                    # tensors — drop them so the next prefill re-allocates
+                    # fresh (skip our ContiguousKVCache which uses pool
+                    # buffers, not bare arrays).
+                    if (
+                        hasattr(c, "keys")
+                        and c.keys is not None
+                        and not hasattr(c, "_k_buffers")
+                    ):
+                        c.keys = None
+                        c.values = None
+                elif hasattr(c, "reset"):
+                    c.reset()
+                elif hasattr(c, "cache"):
+                    # ArraysCache (DeltaNet recurrent state) — drop arrays
+                    # so the next prefill rebuilds. Without this the next
+                    # request inherits the previous request's conv_state /
+                    # ssm_state and produces garbage.
+                    try:
+                        c.cache = [None for _ in c.cache]
+                    except Exception:
+                        pass
+                    # Also reset the length tracker — DeltaNet's GatedDeltaNet
+                    # branches on ``cache.lengths is not None`` to decide
+                    # whether to advance the conv_state pointer. A stale
+                    # tensor from a prior request causes a broadcast
+                    # mismatch on the next prefill (e.g. (1,24,26,64) vs
+                    # (1,1,24,64) — the cache thinks it already has 2
+                    # tokens cached but we just gave it 24 fresh ones).
+                    if hasattr(c, "lengths"):
+                        try:
+                            c.lengths = None
+                        except Exception:
+                            pass
