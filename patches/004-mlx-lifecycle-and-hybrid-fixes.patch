+    def _detect_hybrid(self) -> bool:
+        """Return True if the model has DeltaNet / mamba / GDN layers.
+
+        Hybrid models alternate per-layer cache types — the standard
+        attention layers use ``KVCache``, the linear-attention / SSM
+        layers use ``ArraysCache``. The batched-decode path's uniform
+        ``OffsetCache`` shim doesn't carry conv_state / ssm_state, so
+        DeltaNet layers produce garbage at batch > 1 without per-request
+        ArraysCache routing. This flag triggers a serial-per-request
+        decode fallback in ``decode_batch_start``.
+        """
+        try:
+            maker = getattr(self.model, "make_cache", None) or getattr(
+                getattr(self.model, "language_model", None), "make_cache", None
+            )
+            if maker is None:
+                return False
+            sample = maker()
+            for layer_cache in sample:
+                name = type(layer_cache).__name__
+                if name in ("ArraysCache", "MambaCache", "RecurrentCache"):
+                    return True
+            return False
+        except Exception as e:
+            logger.debug(f"_detect_hybrid failed ({e}); assuming non-hybrid")
+            return False
