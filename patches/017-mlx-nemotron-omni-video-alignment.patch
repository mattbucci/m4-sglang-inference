+        # Dynamic resolution config.
+        # Patch 017 (2026-05-16, MLX-only): force dynamic_resolution=False
+        # on the MLX backend so SGLang's per-image num_tokens (from
+        # compute_budgeted_image_sizes) matches mlx_vlm's vision-tower
+        # feature count exactly. Under dynamic, per-image rounding produces
+        # an off-by-N mismatch (e.g. 1541 placeholders vs 1536 features
+        # for 6-frame probe_video) — _merge_features then ValueErrors. The
+        # static tile path (preprocess_image with fixed image_size,
+        # render_image with constant num_image_token per tile) gives
+        # `tiles × num_image_token` tokens === `tiles × num_image_token`
+        # features. Upstream dynamic path stays enabled on CUDA/ROCm where
+        # the SGLang Nemotron model code does its own dynamic-aware merge.
+        import os as _os
+        if _os.environ.get("SGLANG_USE_MLX") == "1":
+            self.dynamic_resolution = False
+        else:
+            self.dynamic_resolution = getattr(hf_config, "dynamic_resolution", False)
         self.min_num_patches = getattr(hf_config, "min_num_patches", 0)
         self.max_num_patches = getattr(hf_config, "max_num_patches", 0)
         self.patch_size = hf_config.patch_size
